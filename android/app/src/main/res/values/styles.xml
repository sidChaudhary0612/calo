<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — forces dark everywhere -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#6B46FF</item>
        <item name="colorPrimaryDark">#070710</item>
        <item name="colorAccent">#00E5FF</item>
        <item name="android:windowBackground">#070710</item>
        <item name="android:statusBarColor">#070710</item>
        <item name="android:navigationBarColor">#070710</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">#070710</item>
    </style>

    <!-- Splash screen — keep background dark so there's no white flash -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/splash</item>
        <item name="android:statusBarColor">#070710</item>
        <item name="android:navigationBarColor">#070710</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>